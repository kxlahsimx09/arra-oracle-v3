# brew-ops-bot config
# Copy to ~/.cache/brew-ops-bot/.env and chmod 600
# (.env file is gitignored; only this .example lives in the repo)

BREW_OPS_BOT_TOKEN=your-bot-token-from-botfather
BREW_OPS_BOT_CHAT=your-chat-id

# Optional overrides:
# STATE_DIR=$HOME/.cache/brew-ops-bot
# LOG_FILE=$STATE_DIR/bot.log
# DETECTOR_LOG_FILE=$STATE_DIR/detector.log
# POLL=300                        # detector cadence (seconds)
